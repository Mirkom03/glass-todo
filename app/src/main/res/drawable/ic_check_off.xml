<!-- The app's TaskCheck, unchecked: a 1.5dp ring in Chalk2 at 45% alpha on nothing. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp" android:height="24dp"
    android:viewportWidth="24" android:viewportHeight="24">
    <!-- r=10.5: the stroke's outer edge must clear the 24-viewport by a full pixel, or Robolectric's
         renderer clips the flat top/bottom arcs on rows whose subpixel offset lands badly. -->
    <path android:strokeColor="#739BA3B4" android:strokeWidth="1.5" android:fillColor="#00000000"
        android:pathData="M12,1.5a10.5,10.5 0 1,0 0,21a10.5,10.5 0 1,0 0,-21z" />
</vector>
