    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:pathData="M31,53 L44,68"
        android:strokeColor="#35E0F0"
        android:strokeWidth="7"
        android:strokeLineCap="round" />
    <path
        android:pathData="M43,67 L69,33"
        android:strokeColor="#35E0F0"
        android:strokeWidth="11"
        android:strokeLineCap="round" />
    <path
        android:pathData="M79,68 m-4.5,0 a4.5,4.5 0 1,0 9,0 a4.5,4.5 0 1,0 -9,0"
        android:fillColor="#35E0F0" />
